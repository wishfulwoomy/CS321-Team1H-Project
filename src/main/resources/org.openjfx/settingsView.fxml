<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.org.example.views.SettingsViewController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
   <Label text="Text Size:" />

    <Slider fx:id="sizeSlider" accessibleText="Adjust Text Size" blockIncrement="1.0" majorTickUnit="12.0" max="72.0" min="12.0" showTickLabels="true" showTickMarks="true" snapToTicks="true" value="12.0" />

    <CheckBox fx:id="highContrastBox" accessibleText="Enable High Contrast" mnemonicParsing="false" onAction="#toggleHighContrast" text="Enable High Contrast" />

    <Button mnemonicParsing="false" onAction="#closeSettings" text="Close Settings" />
</VBox>
